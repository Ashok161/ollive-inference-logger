# LLM providers (set at least one)
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile

# Services
DATABASE_URL=postgresql+asyncpg://ollive:ollive@postgres:5432/ollive
DATABASE_URL_SYNC=postgresql://ollive:ollive@postgres:5432/ollive
REDIS_URL=redis://redis:6379/0
INGESTION_QUEUE=inference_logs
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SDK / app
INGESTION_URL=http://api:8000/v1/ingest
INGESTION_API_KEY=dev-ingest-key
CONTEXT_WINDOW_MESSAGES=12
PII_REDACTION_ENABLED=true